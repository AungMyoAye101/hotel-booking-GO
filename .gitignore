# =========================
# Global / OS / Editor
# =========================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/
*.log

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =========================
# Client (Next.js 16)
# =========================
# dependencies
/client/node_modules/
/client/.pnp
/client/.pnp.js

# testing
/client/coverage/

# next.js
/client/.next/
/client/out/
/client/build/

# misc
/client/.swc
/client/.vercel/

# env files (Ignore all except example files)
!/client/.env
!/client/.env.*
!/client/.env*.example
!/client/.env*.local.example

# debug
/client/npm-debug.log*
/client/yarn-debug.log*
/client/yarn-error.log*

# =========================
# Go Server (Go + Air)
# =========================
# Air hot-reload build directory (default is tmp/)
/go-server/tmp/

# Compiled binaries
/go-server/bin/
/go-server/main
/go-server/*.exe
/go-server/*.exe~
/go-server/*.dll
/go-server/*.so
/go-server/*.dylib
/go-server/*.gocache
/go-server/.gocache/


# Test binary, built with `go test -c`
/go-server/*.test

# Output of the go coverage tool, specifically when used with LiteIDE
/go-server/*.out

# Dependency directories (if using vendor mode)
/go-server/vendor/

# Go workspace file (optional: keep if you want to share workspace config, ignore if purely local)
# go.work
# go.work.sum

# env files
/go-server/.env
/go-server/.env.*
!/go-server/.env*.example